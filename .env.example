# ─── AI / Groq ────────────────────────────────────────────────────────────────
# Groq API key — https://console.groq.com
GROQ_API_KEY=
# Model ID (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Google Sheets Webhooks (Apps Script) ────────────────────────────────────
# Lead capture + newsletter subscriptions → main sheet
GOOGLE_SHEETS_WEBHOOK_URL=
# Admin notifications for Ajay sir (new lead alerts)
ADMIN_SHEETS_WEBHOOK_URL=

# ─── Endpoint Protection ──────────────────────────────────────────────────────
# Protects /api/cron/* routes (Vercel sends: Authorization: Bearer <secret>)
CRON_SECRET=
# Protects /api/lic-plans/sync (manual LIC plan sync endpoint)
SYNC_SECRET=
# Protects /api/admin/* routes
ADMIN_SECRET=
# Password for /admin dashboard (set a strong password, add to Vercel env vars)
ADMIN_DASHBOARD_PASSWORD=

# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# ─── Email Service (Resend) ──────────────────────────────────────────────────
# Sign up at resend.com (free: 3000 emails/month), verify poddarwealth.com domain
RESEND_API_KEY=

# ─── Sentry Error Tracking ───────────────────────────────────────────────────
# Add DSN from https://sentry.io after creating project
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── WhatsApp Business API (Meta) ────────────────────────────────────────────
# Get these after Meta Business verification (takes 2-4 weeks)
# Dashboard: business.facebook.com → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
